# ============== 1. VSCode本地配置（仅你本地生效，无需提交） ==============
.vscode/
*.code-workspace


# ============== 2. 编译产物（嵌入式项目核心忽略项） ==============
# 编译输出目录（根据你的项目实际目录名调整，比如build/dist/output）
build/


# 目标文件/二进制文件
*.o
*.obj
*.elf
*.bin
*.hex
*.axf
*.lib
*.dll
*.exe


# ============== 3. 编译中间文件/日志 ==============
*.map
*.lst
*.asm
*.d
*.dep
*.log
*.bak


# ============== 4. IDE缓存/用户配置（保留项目配置，忽略个人偏好） ==============
# Keil MDK 用户配置（保留.uvprojx/.uvoptx项目配置，忽略用户特定的uvguix）
*.uvguix.*
*.uvguix.*.bak

# IAR 用户配置
*.ewp.user
*.eww.user
*.dep
*.iobj
*.ihex


# ============== 5. 系统临时文件 ==============
.DS_Store
Thumbs.db